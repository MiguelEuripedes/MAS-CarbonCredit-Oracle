# ── Hyperledger Besu ───────────────────────────────────────────────────────────
BESU_RPC_URL=http://localhost:8545
BESU_CHAIN_ID=1337

# ── Role separation: 3 accounts ────────────────────────────────────────────────
# Account 1 — owner/deployer ONLY (never signs operational transactions)
OWNER_PRIVATE_KEY=0xACCOUNT_1_PRIVATE_KEY
OWNER_ADDRESS=0xACCOUNT_1_ADDRESS

# Account 2 — emission logger + validator (signs logEmission + validateEmission)
EMISSION_PRIVATE_KEY=0xACCOUNT_2_PRIVATE_KEY
EMISSION_ADDRESS=0xACCOUNT_2_ADDRESS

# Account 3 — governance + minter (signs updateGovernanceStatus + issueCredit)
GOVERNANCE_PRIVATE_KEY=0xACCOUNT_3_PRIVATE_KEY
GOVERNANCE_ADDRESS=0xACCOUNT_3_ADDRESS

# ── Contract addresses (auto-filled by deploy_contracts.py) ────────────────────
EMISSIONS_REGISTRY_ADDRESS=
CARBON_CREDIT_ADDRESS=

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Max output tokens per LLM response (Ollama default 128 truncates rationales)
OLLAMA_NUM_PREDICT=1024

# ── Vehicle defaults ───────────────────────────────────────────────────────────
DEFAULT_ENGINE_CC=2000

# ── Carbon credit policy ───────────────────────────────────────────────────────
CO2_PER_CREDIT_GRAM=1000
# Per-km baseline: 180 g/km = global LDV average (IPCC AR5 WGIII, 2014, Chapter 8)
# Credits issued when actual_co2 < baseline_co2_g_per_km × distance_km
BASELINE_CO2_G_PER_KM=180
# Fallback (mg) used only when session has no speed/distance data
BASELINE_CO2_MG=200000

# ── CCT pricing ────────────────────────────────────────────────────────────────
# Fixed EUR price per CCT (1 CCT = 1 kg CO2). Snapshot from the European carbon
# exchange ÷ 1000 (e.g. EU ETS ~€80/tonne → €0.080/kg). Record the snapshot date.
# 29/05/2026
CCT_EUR_RATE=0.080 
# Fixed EUR → BRL exchange rate (manual snapshot — record the date used).
EUR_BRL_RATE=5.90

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_VEHICLE_PER_HOUR=5
MIN_SESSION_GAP_SECONDS=300

# ── Statistical validation ─────────────────────────────────────────────────────
STAT_VALIDATION_MIN_HISTORY=5
STAT_VALIDATION_Z_THRESHOLD=3.0

# ── Physical plausibility (deterministic, history-independent hard rejects) ─────
# Guards against frauds statistics alone miss (impossible speed, engine-off motion,
# hacked temperature sensor, robotic zero-variance data).
MAX_PLAUSIBLE_SPEED_KMH=200     # speed above this = GPS spoofing (also caps distance)
ENGINE_OFF_SPEED_KMH=5          # speed above this with rpm==0 = towed/simulated
MIN_PLAUSIBLE_TEMP_C=-40        # intake-air-temp lower bound (°C)
MAX_PLAUSIBLE_TEMP_C=80         # intake-air-temp upper bound (°C)
ROBOTIC_MIN_ROWS=20             # min rows before robotic check applies
ROBOTIC_RPM_STD_MIN=1.0         # rpm std below this over a long trace = machine-generated
